# Copy to .env.local and fill in. Supabase: Project Settings → API.
# Keep .env.local gitignored (*.local). Never commit real keys.

# --- Vite (browser) — only variables prefixed with VITE_ are exposed to the client ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Optional: same value as above if you prefer the new publishable env name
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# --- Server-side only (NOT read by Vite; do NOT use a VITE_ prefix here) ---
# Service role: full DB access. Use only in local scripts, CI, or set as Edge Function
# secrets in the Supabase dashboard — never ship this key in frontend bundles.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key
